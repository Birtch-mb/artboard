# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects this automatically when you add a PostgreSQL plugin.
DATABASE_URL=postgresql://user:password@host:5432/artboard

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway injects this automatically when you add a Redis plugin.
REDIS_URL=redis://default:password@host:6379

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
# Found in Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=artboard-assets

# ── Authentication ────────────────────────────────────────────────────────────
# Generate strong random secrets: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
NEXTAUTH_SECRET=

# ── URLs (set to production Railway service URLs) ─────────────────────────────
NEXTAUTH_URL=https://your-web-service.up.railway.app
API_URL=https://your-api-service.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=https://your-api-service.up.railway.app/api/v1

# ── API port ──────────────────────────────────────────────────────────────────
PORT=3001

# ── Optional ──────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
